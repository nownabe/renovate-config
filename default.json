{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    // config:recommended, expanded inline so we can drop
    // :semanticPrefixFixDepsChoreOthers (it forces fix/chore commit types and
    // can't be subtracted from the bundle). Keep in sync with upstream when
    // bumping Renovate: lib/config/presets/internal/config.preset.ts (v43.272.0).
    ":dependencyDashboard",
    ":ignoreModulesAndTests",
    "group:monorepos",
    "group:recommended",
    "mergeConfidence:age-confidence-badges",
    "replacements:all",
    "workarounds:all",
    "helpers:forgejoDigestChangelogs",
    "helpers:giteaDigestChangelogs",
    "helpers:githubDigestChangelogs",
    "helpers:gitlabDigestChangelogs",
    "helpers:goXPackagesChangelogLink",
    "helpers:goXPackagesNameLink",
    "helpers:renovateChangelog",

    "security:openssf-scorecard",
    ":semanticCommits",
    // Update versions annotated with "# renovate: datasource=... depName=..."
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "customManagers:makefileVersions"
  ],

  // Auto-create PRs migrating deprecated Renovate config options
  "configMigration": true,

  // Interpret all schedules in JST instead of the default UTC
  "timezone": "Asia/Tokyo",

  // Runtime dependencies use "deps"; non-runtime updates are demoted to "chore"
  // in packageRules below.
  "semanticCommitType": "deps",
  // No scope by default; packageRules below add per-manager scopes.
  "semanticCommitScope": null,

  // Label all Renovate PRs
  "labels": ["renovate"],

  // Limit concurrent PRs to avoid overwhelming CI and reviewers.
  // Disable the hourly limit (default 2): Renovate runs once a day via ghac,
  // so the hourly limit would cap new PRs at 2 per day.
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,

  // Automerge all PRs after CI passes
  "automerge": true,
  "platformAutomerge": true,

  // Commit via the GitHub API so commits are signed by the GitHub App
  // (rulesets require signed commits on default branches)
  "platformCommit": "enabled",

  // Wait before creating PRs to avoid compromised packages
  "minimumReleaseAge": "3 days",

  // Also check the OSV database, not just GitHub's vulnerability alerts
  "osvVulnerabilityAlerts": true,

  // Vulnerability fix PRs should be created immediately and prioritized
  "vulnerabilityAlerts": {
    "enabled": true,
    "addLabels": ["deps/security"],
    "schedule": ["at any time"],
    "assignees": ["nownabe"]
  },

  // Update the mise version pinned in workflow files
  // (lines annotated with "# renovate:mise-version")
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/"],
      "matchStrings": ["version: (?<currentValue>\\S+) # renovate:mise-version"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "jdx/mise",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ],

  "packageRules": [
    // Pin Docker image tags to digests for immutable references
    // (GitHub Actions pinning is enforced platform-wide by ghac's
    // sha_pinning_required, so no preset is needed for it)
    {
      "matchDatasources": ["docker"],
      "pinDigests": true
    },

    // Demote non-runtime updates to "chore" (CI actions, container images,
    // infra, tool-version managers).
    {
      "matchManagers": [
        "github-actions",
        "dockerfile",
        "docker-compose",
        "terraform",
        "mise",
        "custom.regex"
      ],
      "semanticCommitType": "chore"
    },
    {
      "matchDepTypes": ["devDependencies", "optionalDependencies", "peerDependencies", "engines"],
      "semanticCommitType": "chore"
    },
    {
      "matchJsonata": ["isLockfileUpdate = true"],
      "semanticCommitType": "chore"
    },

    // Semantic commit scope per manager
    {
      "matchManagers": ["github-actions"],
      "semanticCommitScope": "github-actions"
    },
    {
      "matchManagers": ["npm"],
      "semanticCommitScope": "npm"
    },
    {
      "matchManagers": ["gomod"],
      "semanticCommitScope": "go"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "semanticCommitScope": "docker"
    },
    {
      "matchManagers": ["terraform"],
      "semanticCommitScope": "terraform"
    },
    {
      "matchManagers": ["mise"],
      "semanticCommitScope": "mise"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["jdx/mise"],
      "semanticCommitScope": "mise"
    },

    // GitHub Actions: group non-major, individual for major
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github actions (non-major)"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["deps/major"],
      "automerge": false
    },

    // mise tool versions
    // Workaround: run `mise lock` after mise.toml updates until Renovate
    // natively supports mise lockfile maintenance (renovatebot/renovate#40568).
    //
    // `mise trust` runs before `mise lock`: this preset targets a self-hosted
    // Renovate (nownabe/ghac) that clones each repo into a fresh temp directory
    // before running postUpgradeTasks. A freshly cloned directory is untrusted
    // (not in mise's trust store), so `mise lock` couldn't read mise.toml
    // without trusting it first. This applies to every repo that uses mise.
    //
    // executionMode: "branch" (non-major only) runs the task once per branch
    // after all updates are applied, instead of the default "update" (once per
    // tool). Non-major updates group multiple tools into a single branch/PR,
    // and `mise lock` regenerates the whole lockfile from mise.toml's final
    // state, so running it per-tool would be wasteful and operate on
    // intermediate state. Major updates get individual PRs (one tool per
    // branch), so per-tool already means per-branch and "branch" isn't needed.
    //
    // (`mise trust`/`mise lock` must be allowlisted in the self-hosted admin's
    // allowedCommands; already configured in ghac's renovate-config.js. That
    // option can't be set from a repo-level preset, so nothing to do here.)
    {
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "mise tools (non-major)",
      "postUpgradeTasks": {
        "commands": ["mise trust", "mise lock"],
        "fileFilters": ["mise.lock"],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["deps/major"],
      "automerge": false,
      "postUpgradeTasks": {
        "commands": ["mise trust", "mise lock"],
        "fileFilters": ["mise.lock"]
      }
    }
  ]
}
