{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "security:openssf-scorecard",
    ":dependencyDashboard",
    ":semanticCommits",
    // Update versions annotated with "# renovate: datasource=... depName=..."
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "customManagers:makefileVersions",
  ],

  // Auto-create PRs migrating deprecated Renovate config options
  configMigration: true,

  // Interpret all schedules in JST instead of the default UTC
  timezone: "Asia/Tokyo",

  // Use "deps" as semantic commit type for all Renovate PRs.
  // No scope by default ("deps: ..."); packageRules below add
  // per-manager scopes ("deps(mise): ..." etc.)
  semanticCommitType: "deps",
  semanticCommitScope: null,

  // Label all Renovate PRs
  labels: ["renovate"],

  // Limit concurrent PRs to avoid overwhelming CI and reviewers.
  // Disable the hourly limit (default 2): Renovate runs once a day via ghac,
  // so the hourly limit would cap new PRs at 2 per day.
  prConcurrentLimit: 5,
  prHourlyLimit: 0,

  // Automerge all PRs after CI passes
  automerge: true,
  platformAutomerge: true,

  // Commit via the GitHub API so commits are signed by the GitHub App
  // (rulesets require signed commits on default branches)
  platformCommit: "enabled",

  // Wait before creating PRs to avoid compromised packages
  minimumReleaseAge: "3 days",

  // Also check the OSV database, not just GitHub's vulnerability alerts
  osvVulnerabilityAlerts: true,

  // Vulnerability fix PRs should be created immediately and prioritized
  vulnerabilityAlerts: {
    enabled: true,
    addLabels: ["deps/security"],
    schedule: ["at any time"],
    assignees: ["nownabe"],
  },

  // Update the mise version pinned in workflow files
  // (lines annotated with "# renovate:mise-version")
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/.+\\.ya?ml$/"],
      matchStrings: ["version: (?<currentValue>\\S+) # renovate:mise-version"],
      datasourceTemplate: "github-releases",
      depNameTemplate: "jdx/mise",
      extractVersionTemplate: "^v(?<version>.+)$",
    },
  ],

  packageRules: [
    // Pin Docker image tags to digests for immutable references
    // (GitHub Actions pinning is enforced platform-wide by ghac's
    // sha_pinning_required, so no preset is needed for it)
    {
      matchDatasources: ["docker"],
      pinDigests: true,
    },

    // Semantic commit scope per manager
    {
      matchManagers: ["github-actions"],
      semanticCommitScope: "github-actions",
    },
    {
      matchManagers: ["npm"],
      semanticCommitScope: "npm",
    },
    {
      matchManagers: ["gomod"],
      semanticCommitScope: "go",
    },
    {
      matchManagers: ["dockerfile", "docker-compose"],
      semanticCommitScope: "docker",
    },
    {
      matchManagers: ["terraform"],
      semanticCommitScope: "terraform",
    },
    {
      matchManagers: ["mise"],
      semanticCommitScope: "mise",
    },
    {
      matchManagers: ["custom.regex"],
      matchDepNames: ["jdx/mise"],
      semanticCommitScope: "mise",
    },

    // GitHub Actions: group non-major, individual for major
    {
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "github actions (non-major)",
    },
    {
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["major"],
      addLabels: ["deps/major"],
      automerge: false,
    },

    // mise tool versions
    // Workaround: run `mise lock` after mise.toml updates until Renovate
    // natively supports mise lockfile maintenance (renovatebot/renovate#40568).
    {
      matchManagers: ["mise"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "mise tools (non-major)",
      postUpgradeTasks: {
        commands: ["mise lock"],
        fileFilters: ["mise.lock"],
      },
    },
    {
      matchManagers: ["mise"],
      matchUpdateTypes: ["major"],
      addLabels: ["deps/major"],
      automerge: false,
      postUpgradeTasks: {
        commands: ["mise lock"],
        fileFilters: ["mise.lock"],
      },
    },
  ],
}
